.vscode/
*.swp
*.swo

# ── Figures — generated outputs, not tracked ─────────────────────────────────
computations/analysis/outputs/figures/*.png
computations/analysis/outputs/figures/*.svg
computations/analysis/outputs/figures/*.eps


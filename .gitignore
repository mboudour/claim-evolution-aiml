*.fdb_latexmk

# ── API keys and credentials — never expose ───────────────────────────────────
config/
*.key
*.env
.env
*.secret
openai_key.txt
dimensions_key.txt
*_key.txt
*_token.txt

# ── LLM outputs — raw API responses not tracked ───────────────────────────────
*_raw.txt
*_responses.jsonl
*_llm_output*


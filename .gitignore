# ── Spreadsheets ──────────────────────────────────────────────────────────────
*.xlsx
*.xls
*.ods

# ── Documents and outputs — manuscript added manually at submission ───────────
*.pdf
*.tex
*.bib
*.aux
*.log
*.out
*.toc
*.bbl
*.blg
*.synctex.gz
